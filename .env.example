# Noir Factory Environment Variables

# === Required for Production ===
# Supabase Configuration (Multi-tenant database)
SUPABASE_URL=https://ghzvppbkuudkpzlcidlx.supabase.co
SUPABASE_SERVICE_KEY=your_service_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# CORS Configuration
CORS_ORIGINS=https://noir-factory-production-control-230432435181.us-west1.run.app,https://app.noir-factory.com

# === Server Configuration ===
PORT=8080
NODE_ENV=production
LOG_LEVEL=info

# === Meta Business Suite (Optional) ===
# For direct posting to Facebook, Instagram, and Threads
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here
META_REDIRECT_URI=http://localhost:8080/api/integrations/meta/callback

# === Engagement Bot (Optional) ===
# Cron expression for bot interval (default: */5 * * * * = every 5 minutes)
ENGAGEMENT_BOT_INTERVAL=*/5 * * * *

# === External Services (Optional) ===
# Screenshot Service
SCREENSHOTONE_API_KEY=your_key_here

# AI/LLM Service
OPENROUTER_API_KEY=your_key_here

# RunPod GPU Worker
RUNPOD_API_KEY=your_key_here
RUNPOD_WORKER_URL=https://api.runpod.ai/v2/your-endpoint

# Shotstack Video Service
SHOTSTACK_API_KEY=your_key_here
SHOTSTACK_ENV=v1
SHOTSTACK_CALLBACK_URL=https://your-backend.run.app/api/production/shotstack/callback

# TTS Service
TTS_SERVICE_URL=https://your-tts-service.com
TTS_VOICE=noir_male
TTS_TIMEOUT=120000

# Metricool Social Media
METRICOOL_API_KEY=your_key_here
METRICOOL_BASE_URL=https://api.metricool.com/v1
METRICOOL_DEFAULT_PLATFORM=instagram

# Publer Social Media Management
PUBLER_API_KEY=your_key_here
PUBLER_WORKSPACE_ID=your_workspace_id_here
PUBLER_ACCOUNT_ID=your_account_id_here

# Airtable (Legacy integration)
AIRTABLE_TOKEN=your_token_here
AIRTABLE_BASE_ID=your_base_id_here

# HTMLCSStoImage (Screenshot rendering)
HCTI_USER_ID=your_user_id_here
HCTI_API_KEY=your_api_key_here

# Segmind (TTS + SadTalker)
SEGMIND_API_KEY=your_api_key_here

# === Cloudflare Analytics (Optional — for health monitor) ===
CF_ANALYTICS_TOKEN=your_cf_analytics_token_here
CF_ZONE_PROXITAP=your_proxitap_zone_id_here
CF_ZONE_ALLADRE=your_alladre_zone_id_here

# === RSS Feed (Optional) ===
REDDIT_RSS_URL=https://rss.app/feeds/your-feed.xml
RSS_CHECK_INTERVAL=*/15 * * * *

# === Other (Optional) ===
TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
